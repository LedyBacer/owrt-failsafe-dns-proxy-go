msgid "Failsafe DNS Proxy"
msgstr "Резервный DNS-прокси"

msgid "Strict-priority DNS failover with active health checks and automatic failback."
msgstr "DNS failover со строгим приоритетом, активными проверками и автоматическим возвратом."

msgid "General settings"
msgstr "Общие настройки"

msgid "Allow daemon to run"
msgstr "Разрешить запуск daemon"

msgid "When disabled, the init script exits without starting the daemon. Autostart is controlled in the runtime status panel."
msgstr "Если выключено, init-скрипт завершится без запуска daemon. Автозапуск управляется в панели текущего состояния."

msgid "Listen address"
msgstr "Адрес прослушивания"

msgid "Listen port"
msgstr "Порт прослушивания"

msgid "Attempt timeout (ms)"
msgstr "Таймаут попытки (мс)"

msgid "Total request timeout (ms)"
msgstr "Общий таймаут запроса (мс)"

msgid "Health check interval (s)"
msgstr "Интервал проверки состояния (с)"

msgid "Failure threshold"
msgstr "Порог ошибок"

msgid "Recovery threshold"
msgstr "Порог восстановления"

msgid "Maximum concurrent requests"
msgstr "Максимум одновременных запросов"

msgid "Probe questions"
msgstr "Проверочные DNS-запросы"

msgid "Use the format domain:A or domain:AAAA."
msgstr "Формат: domain:A или domain:AAAA."

msgid "Expected domain:A or domain:AAAA"
msgstr "Ожидается domain:A или domain:AAAA"

msgid "Upstreams"
msgstr "Вышестоящие DNS-серверы"

msgid "Upstreams are tried by ascending numeric priority."
msgstr "Серверы проверяются по возрастанию числового приоритета."

msgid "Enabled"
msgstr "Включён"

msgid "Priority"
msgstr "Приоритет"

msgid "Protocol"
msgstr "Протокол"

msgid "IP address"
msgstr "IP-адрес"

msgid "Port"
msgstr "Порт"

msgid "Test"
msgstr "Проверить"

msgid "Runtime status"
msgstr "Текущее состояние"

msgid "Service"
msgstr "Сервис"

msgid "Active upstream"
msgstr "Активный DNS-сервер"

msgid "Start"
msgstr "Запустить"

msgid "Restart"
msgstr "Перезапустить"

msgid "Stop"
msgstr "Остановить"

msgid "Enable autostart"
msgstr "Включить автозапуск"

msgid "Disable autostart"
msgstr "Отключить автозапуск"

msgid "Check configuration"
msgstr "Проверить конфигурацию"

msgid "Name"
msgstr "Имя"

msgid "Endpoint"
msgstr "Адрес"

msgid "State"
msgstr "Состояние"

msgid "Failures"
msgstr "Ошибки"

msgid "Latency"
msgstr "Задержка"

msgid "Last success"
msgstr "Последний успех"

msgid "Last error"
msgstr "Последняя ошибка"

msgid "Operational log"
msgstr "Журнал переключений"

msgid "dnsmasq integration"
msgstr "Интеграция с dnsmasq"

msgid "Integration is explicit and reversible. The current dnsmasq configuration is backed up and automatically restored if verification fails."
msgstr "Интеграция выполняется явно и обратимо. Текущая конфигурация dnsmasq сохраняется и автоматически восстанавливается, если проверка завершается ошибкой."

msgid "Enabled: dnsmasq uses %s"
msgstr "Включено: dnsmasq использует %s"

msgid "Disabled: dnsmasq configuration is unchanged"
msgstr "Отключено: конфигурация dnsmasq не изменена"

msgid "Dry run"
msgstr "Предварительная проверка"

msgid "Enable integration"
msgstr "Включить интеграцию"

msgid "Disable and restore"
msgstr "Отключить и восстановить"

msgid "Preflight checks passed."
msgstr "Предварительные проверки пройдены."

msgid "dnsmasq integration enabled."
msgstr "Интеграция с dnsmasq включена."

msgid "dnsmasq integration disabled."
msgstr "Интеграция с dnsmasq отключена."

msgid "Running, version %s"
msgstr "Работает, версия %s"

msgid "Running, version %s; autostart %s"
msgstr "Работает, версия %s; автозапуск %s"

msgid "Stopped; autostart %s"
msgstr "Остановлен; автозапуск %s"

msgid "Stopped; startup disabled in configuration"
msgstr "Остановлен; запуск отключён в конфигурации"

msgid "enabled"
msgstr "включён"

msgid "disabled"
msgstr "отключён"

msgid "Unknown"
msgstr "Неизвестно"

msgid "Healthy"
msgstr "Работает"

msgid "Suspect"
msgstr "Подозрение на сбой"

msgid "Down"
msgstr "Недоступен"

msgid "Recovering"
msgstr "Восстанавливается"

msgid "No runtime status available."
msgstr "Текущее состояние недоступно."

msgid "No operational log entries."
msgstr "Записей о переключениях пока нет."

msgid "Configuration is valid"
msgstr "Конфигурация корректна"

msgid "Operation failed"
msgstr "Операция завершилась ошибкой"

msgid "Unknown error"
msgstr "Неизвестная ошибка"

msgid "Start and stop control the current daemon process. Autostart controls whether OpenWrt starts it during boot."
msgstr "Запуск и остановка управляют текущим процессом daemon. Автозапуск определяет, будет ли OpenWrt запускать его при загрузке."

msgid "Autostart enabled"
msgstr "Автозапуск включён"

msgid "Autostart disabled"
msgstr "Автозапуск отключён"

msgid "Unable to determine upstream to test."
msgstr "Не удалось определить DNS-сервер для проверки."

msgid "Working…"
msgstr "Выполняется…"

msgid "The command completed, but the expected state was not observed."
msgstr "Команда завершилась, но ожидаемое состояние не подтвердилось."

msgid "Starting…"
msgstr "Запуск…"

msgid "Service started"
msgstr "Сервис запущен"

msgid "Service did not report as running after start."
msgstr "После запуска сервис не сообщил, что работает."

msgid "Restarting…"
msgstr "Перезапуск…"

msgid "Service restarted"
msgstr "Сервис перезапущен"

msgid "Service did not report as running after restart."
msgstr "После перезапуска сервис не сообщил, что работает."

msgid "Stopping…"
msgstr "Остановка…"

msgid "Service stopped"
msgstr "Сервис остановлен"

msgid "Service still reports as running after stop."
msgstr "После остановки сервис всё ещё сообщает, что работает."

msgid "Applying…"
msgstr "Применение…"

msgid "Autostart did not report as enabled."
msgstr "Автозапуск не подтвердил включённое состояние."

msgid "Autostart still reports as enabled."
msgstr "Автозапуск всё ещё сообщает, что включён."

msgid "Checking…"
msgstr "Проверка…"

msgid "Enabling…"
msgstr "Включение…"

msgid "dnsmasq integration did not report as enabled."
msgstr "Интеграция с dnsmasq не подтвердила включённое состояние."

msgid "Restoring…"
msgstr "Восстановление…"

msgid "dnsmasq integration still reports as enabled."
msgstr "Интеграция с dnsmasq всё ещё сообщает, что включена."
